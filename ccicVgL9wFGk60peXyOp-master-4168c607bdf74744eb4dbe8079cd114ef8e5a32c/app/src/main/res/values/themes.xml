<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 - Material Design 3 with iOS 风格 -->
    <style name="Theme.TiShou" parent="Theme.Material3.Light.NoActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        
        <!-- 次要色 -->
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorSecondaryVariant">@color/teal</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        
        <!-- 背景色 -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- 错误色 -->
        <item name="colorError">@color/status_error</item>
        <item name="colorOnError">@color/text_on_primary</item>
        
        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        
        <!-- 窗口动画 -->
        <item name="android:windowAnimationStyle">@style/iOSWindowAnimation</item>
    </style>

    <!-- 深色模式主题 -->
    <style name="Theme.TiShou.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/card_background_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/card_background_dark</item>
    </style>

    <!-- iOS 风格窗口动画 -->
    <style name="iOSWindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/ios_slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/ios_fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/ios_fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/ios_slide_out_right</item>
    </style>

    <!-- iOS 风格卡片样式 -->
    <style name="iOSCardStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- iOS 风格大按钮 -->
    <style name="iOSButton.Large" parent="Widget.Material3.Button">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <!-- iOS 风格开关 -->
    <style name="iOSSwitch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">@color/primary</item>
        <item name="trackTint">@color/stroke_light</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- 启动页主题 -->
    <style name="Theme.TiShou.Splash" parent="Theme.TiShou">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>